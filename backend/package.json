{
  "name": "api-node",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "docker:up": "docker compose up -d",
    "start:all": "npm run docker:up && concurrently -n 'API,WORKER' -c 'blue,green' \"npm run dev\" \"npx ts-node src/workers/documentWorker.ts\"",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "test": "node -r ts-node/register --test",
    "lint": "eslint .",
    "benchmark": "ts-node benchmark/run.ts"
  },
  "dependencies": {
    "bullmq": "^5.58.5",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "mongoose": "^8.18.1",
    "openapi-types": "^12.1.3",
    "opossum": "^9.0.0",
    "pdfkit": "^0.17.2",
    "piscina": "^5.1.4",
    "prom-client": "^15.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^22.18.0",
    "@types/opossum": "^8.1.9",
    "@types/pdfkit": "^0.17.5",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "eslint": "^9.32.0",
    "globals": "^15.15.0",
    "ioredis-mock": "^8.9.0",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
